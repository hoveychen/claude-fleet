[package]
name = "claw-fleet"
version = "26.3.28-dev.1774688608"
description = "Claw Fleet - Monitor all Claude sessions"
authors = ["hoveychen"]
license = "AGPL-3.0-only"
edition = "2021"
default-run = "claw-fleet"

[lib]
name = "claw_fleet_lib"
crate-type = ["staticlib", "cdylib", "rlib"]

[[bin]]
name = "fleet-cli"
path = "src/bin/fleet.rs"

[build-dependencies]
tauri-build = { version = "2", features = [], optional = true }

[dependencies]
# ── GUI-only (gated behind "gui" feature) ─────────────────────────────────────
tauri = { version = "2", features = ["tray-icon"], optional = true }
tauri-plugin-opener = { version = "2", optional = true }
tauri-plugin-single-instance = { version = "2", optional = true }
tauri-plugin-notification = { version = "2.3.3", optional = true }
tauri-plugin-store = { version = "2.4.2", optional = true }
tauri-plugin-clipboard-manager = { version = "2.3.2", optional = true }
tauri-plugin-dialog = { version = "2", optional = true }
notify = { version = "6", optional = true }
rfd = { version = "0.15", optional = true }
image = { version = "0.25", default-features = false, features = ["png"], optional = true }

# ── Shared (used by both GUI and fleet-cli probe) ─────────────────────────────
serde = { version = "1", features = ["derive"] }
serde_json = "1"
dirs = "5"
libc = "0.2"
chrono = { version = "0.4", features = ["serde"] }
reqwest = { version = "0.12", default-features = false, features = ["json", "blocking", "rustls-tls"] }
sysinfo = { version = "0.33", default-features = false, features = ["system"] }
clap = { version = "4", features = ["derive"] }
tiny_http = "0.12"
percent-encoding = "2"
rusqlite = { version = "0.31", features = ["bundled"] }
futures = "0.3"
tokio = { version = "1", features = ["rt", "rt-multi-thread"] }
zstd = "0.13"
msedge-tts = { version = "0.3", optional = true }
rodio = { version = "0.19", default-features = false, features = ["mp3"], optional = true }

[features]
default = []
gui = [
    "tauri", "tauri-build",
    "tauri-plugin-opener", "tauri-plugin-single-instance",
    "tauri-plugin-notification", "tauri-plugin-store",
    "tauri-plugin-clipboard-manager", "tauri-plugin-dialog",
    "notify", "rfd", "image",
]
tts = ["msedge-tts", "rodio"]

[profile.release]
strip = true
lto = true

