<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sidecar (fleet CLI) runs outside the app sandbox because it is
         invoked by external processes (e.g. Claude Code hooks) that are
         not themselves sandboxed.  Sandbox entitlements on a binary
         launched outside the app-bundle context cause SIGTRAP. -->

    <!-- ── Runtime: allow dyld env vars for compatibility ── -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- ── Network (fleet serve, SSE) ── -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>
